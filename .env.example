# Environment variables for object detection project
# Copy this to .env and fill in your values

# Dataset paths
DATASET_PATH=data/raw
OUTPUT_PATH=outputs

# Training settings
BATCH_SIZE=16
NUM_EPOCHS=100
LEARNING_RATE=0.001

# Device settings
DEVICE=cuda

# Weights & Biases (optional)
WANDB_ENABLED=false
WANDB_PROJECT=object-detection
WANDB_ENTITY=your-entity

# Model configuration
MODEL_TYPE=yolov8
CHECKPOINT_PATH=models/checkpoints
